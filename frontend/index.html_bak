<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="The official digital Lost & Found for NMIMS Mumbai. Ensure a fast, trusted, and structured recovery process for lost items across campus.">
  <meta property="og:title" content="CampusFoundIt">
  <meta property="og:description" content="Report, verify, and recover lost items at NMIMS Mumbai securely.">
  <title>CampusFoundIt — NMIMS Mumbai Lost & Found</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="nav">
    <div class="container nav-container">
      <a href="index.html" class="nav-brand">
        CampusFoundIt
      </a>
      <div class="nav-links">
        <a href="index.html" class="nav-link active">Home</a>
        <a href="report-lost.html" class="nav-link">Report Lost Item</a>
        <a href="report-found.html" class="nav-link">Report Found Item</a>
        <a href="browse.html" class="nav-link">Browse Items</a>
        <a href="admin.html" class="nav-link text-muted">Admin</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1>The official digital Lost & Found for NMIMS Mumbai.</h1>
      <p>Report items you have lost, or help secure items you have found. Every match is privately verified to ensure the right items reach the right students.</p>
      <div class="hero-actions">
        <a href="report-lost.html" class="btn btn-primary">Report a Lost Item</a>
        <a href="report-found.html" class="btn btn-outline">Report a Found Item</a>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <div class="stats">
    <div class="stat-item">
      <div class="stat-val" id="stat-reported">
        <span class="skeleton" style="display:inline-block; width:64px; height:36px;"></span>
      </div>
      <div class="stat-desc">Total Reports</div>
    </div>
    <div class="stat-item">
      <div class="stat-val" id="stat-matched">
        <span class="skeleton" style="display:inline-block; width:64px; height:36px;"></span>
      </div>
      <div class="stat-desc">Pairs Matched</div>
    </div>
    <div class="stat-item">
      <div class="stat-val" id="stat-returned">
        <span class="skeleton" style="display:inline-block; width:64px; height:36px;"></span>
      </div>
      <div class="stat-desc">Items Returned</div>
    </div>
  </div>

  <!-- Recent Found Items -->
  <section class="section">
    <div class="container">
      <div class="flex-justify-between mb-8">
        <div>
          <h2>Recently Found Items</h2>
          <p class="text-muted">Browse the latest items handed over by students and staff.</p>
        </div>
        <a href="browse.html" class="btn btn-ghost">View all items &rarr;</a>
      </div>

      <div id="recent-items-container" class="grid-auto">
        <!-- Skeleton Loaders (default state) -->
        <div class="item-card skeleton">
          <div style="height:200px; width:100%;"></div>
          <div class="item-card-content">
            <div class="skeleton-title mb-2"></div>
            <div class="skeleton-text"></div>
            <div class="skeleton-text short"></div>
          </div>
        </div>
        <div class="item-card skeleton">
          <div style="height:200px; width:100%;"></div>
          <div class="item-card-content">
            <div class="skeleton-title mb-2"></div>
            <div class="skeleton-text"></div>
            <div class="skeleton-text short"></div>
          </div>
        </div>
        <div class="item-card skeleton">
          <div style="height:200px; width:100%;"></div>
          <div class="item-card-content">
            <div class="skeleton-title mb-2"></div>
            <div class="skeleton-text"></div>
            <div class="skeleton-text short"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background-color: var(--c-white); border-top: 1px solid var(--c-gray-200);">
    <div class="container">
      <h2>How Recovery Works</h2>
      <p class="text-muted" style="max-width: 600px;">A secure, automated system designed to eliminate unstructured WhatsApp groups and prioritize privacy.</p>
      
      <div class="steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Submit a Report</h3>
          <p>Detail the item you lost or found. Owners must provide a hidden verification detail known only to them.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>System Matching</h3>
          <p>Our algorithm cross-references attributes like category, color, location, and keywords to identify high-probability matches.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Admin Verification</h3>
          <p>The admin reviews algorithmic clusters and cross-references the hidden verification detail against the physical found item.</p>
        </div>
        <div class="step">
          <div class="step-number">04</div>
          <h3>Secure Notification</h3>
          <p>Once verified, the system automatically emails both parties securely. The owner can collect the item from the designated office.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="flex-justify-between">
        <p><strong>CampusFoundIt</strong> &copy; 2026. The official platform for NMIMS Mumbai.</p>
        <p>Built by L023, L028, L034 under Dr. Supriya Agrawal.</p>
      </div>
    </div>
  </footer>

  <script src="js/config.js"></script>
  <script src="js/main.js"></script>
</body>
</html>

